# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:666/callback

# Session Security - Change this to a random secret string in production!
SECRET_KEY=change-me-to-a-random-secret-string

# Optional: CORS origins for the frontend (comma-separated string)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
